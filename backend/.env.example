# Groq API Key - Obtain from https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here

# Qdrant Vector Database Configuration
# Obtain URL and API Key from a free tier cluster on https://cloud.qdrant.io
# For local development with Qdrant in Docker, you can use:
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_URL=https://your-qdrant-cluster-url.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# The collection name in Qdrant for contract vectors
QDRANT_COLLECTION_NAME=legal_contracts

# Maximum allowed size for uploaded files in megabytes (default: 20)
MAX_UPLOAD_SIZE_MB=20

# CORS Allowed Origins - comma-separated list of origins (e.g. http://localhost:3000,http://localhost:5173)
# Set to * to allow all origins during development
ALLOWED_ORIGINS=*
